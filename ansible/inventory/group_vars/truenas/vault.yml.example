---
# Copy this file to vault.yml and encrypt it:
#   ansible-vault encrypt ansible/inventory/group_vars/truenas/vault.yml
#
# Generate an API key in TrueNAS UI: Credentials > API Keys > Add
truenas_api_key: "REPLACE_WITH_YOUR_API_KEY"

# Passwords for users defined in vars.yml under truenas_users
truenas_user_passwords:
  griffin: "REPLACE_WITH_PASSWORD"

# Immich app credentials
immich_db_password:    "REPLACE_WITH_DB_PASSWORD"
immich_redis_password: "REPLACE_WITH_REDIS_PASSWORD"

# Immich API key — generate in Immich web UI: Account Settings > API Keys
immich_api_key: "REPLACE_WITH_IMMICH_API_KEY"

# Tailscale auth key — generate at tailscale.com/admin/settings/keys
# auth_once: true means this is only used on first install; state persists in ix_volume after that
tailscale_auth_key: "REPLACE_WITH_AUTH_KEY"

# Nextcloud credentials — no special chars (&@#%) in redis_password
nextcloud_admin_user:     "REPLACE_WITH_ADMIN_USERNAME"
nextcloud_admin_password: "REPLACE_WITH_ADMIN_PASSWORD"
nextcloud_db_password:    "REPLACE_WITH_DB_PASSWORD"
nextcloud_redis_password: "REPLACE_WITH_REDIS_PASSWORD"

# Cloudflare API token for DNS-01 challenge (wildcard cert issuance).
# Create at dash.cloudflare.com > My Profile > API Tokens > Create Token.
# Use the "Edit zone DNS" template, scoped to griffdawg.dev only.
cloudflare_api_token: "REPLACE_WITH_CLOUDFLARE_API_TOKEN"

# Pi-hole web admin password
pihole_web_password: "REPLACE_WITH_PIHOLE_PASSWORD"
