---
# Copy this file to vault.yml and encrypt it:
#   ansible-vault encrypt ansible/inventory/group_vars/truenas/vault.yml
#
# Generate an API key in TrueNAS UI: Credentials > API Keys > Add
truenas_api_key: "REPLACE_WITH_YOUR_API_KEY"

# Passwords for users defined in vars.yml under truenas_users
truenas_user_passwords:
  griffin: "REPLACE_WITH_PASSWORD"

# Immich app credentials
immich_db_password:    "REPLACE_WITH_DB_PASSWORD"
immich_redis_password: "REPLACE_WITH_REDIS_PASSWORD"

# Tailscale auth key — generate at tailscale.com/admin/settings/keys
# auth_once: true means this is only used on first install; state persists in ix_volume after that
tailscale_auth_key: "REPLACE_WITH_AUTH_KEY"
