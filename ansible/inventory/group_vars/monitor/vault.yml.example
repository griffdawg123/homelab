---
# Copy to vault.yml and encrypt with the SAME vault password as the truenas vault:
#   cp vault.yml.example vault.yml
#   ansible-vault encrypt vault.yml
# Or simply: ./edit_vault.sh monitor
#
# Cloudflare API token (Edit zone DNS on griffdawg.dev) — Caddy on the droplet
# uses it for the kuma.griffdawg.dev cert via DNS-01. This is the SAME token as
# the truenas vault's cloudflare_api_token; paste the same value here.
cloudflare_api_token: "REPLACE_WITH_CLOUDFLARE_API_TOKEN"
